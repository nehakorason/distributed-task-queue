# Copy to .env and fill in for local development
# Never commit the actual .env file

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=taskqueue
DB_USER=taskqueue
DB_PASSWORD=taskqueue

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# API
SERVER_PORT=8080

# Worker
WORKER_ID=worker-local
WORKER_CONCURRENCY=5
API_BASE_URL=http://localhost:8080

# Monitoring
METRICS_PORT=9090
